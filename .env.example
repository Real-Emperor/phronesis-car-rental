# PHRONESIS — Environment Variables
# Copy this file to .env and fill in real values.
# For Vercel, set these in the Vercel project settings (not in the repo).

# PostgreSQL connection string (REQUIRED for production)
# Get a free one from:
#   - Neon:      https://neon.tech
#   - Supabase:  https://supabase.com
#   - Vercel:    https://vercel.com/docs/storage/vercel-postgres
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: override admin password (default is "phronesis2024" from DB settings)
# ADMIN_PASSWORD=your-strong-password
